---
const stats = [
  { value: '81', label: 'İlde Hizmet', suffix: '' },
  { value: '10000', label: 'Mutlu Müşteri', suffix: '+' },
  { value: '7/24', label: 'WhatsApp Destek', suffix: '' },
  { value: '100', label: 'Sigorta Kapsamı', suffix: '%' },
];
---

<section class="bg-primary-800 py-12 md:py-16">
  <div class="max-w-7xl mx-auto px-4">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
      {stats.map((stat) => (
        <div class="text-center">
          <div class="text-3xl md:text-4xl font-extrabold text-accent-400 mb-1">
            {stat.value}{stat.suffix}
          </div>
          <div class="text-gray-300 text-sm md:text-base font-medium">
            {stat.label}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
