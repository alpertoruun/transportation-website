---

<section class="section-padding bg-white" id="neden-biz">
  <div class="container-narrow">
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-bold text-primary-800 mb-4">
        Neden Leventoğlu Nakliyat?
      </h2>
      <p class="text-gray-600 max-w-2xl mx-auto">
        Müşterilerimizin bize güvenmesinin sebeplerini keşfedin.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {reasons.map((reason) => (
        <div class="card group hover:border-accent-200 border border-transparent">
          <div class="w-12 h-12 bg-accent-100 rounded-lg flex items-center justify-center mb-4 group-hover:bg-accent-500 transition-colors">
            <svg class="w-6 h-6 text-accent-600 group-hover:text-white transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={reason.icon} />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-primary-800 mb-2">{reason.title}</h3>
          <p class="text-gray-600 text-sm leading-relaxed">{reason.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
