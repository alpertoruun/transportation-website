---
import { testimonials } from '../data/testimonials';
---

<section class="section-padding bg-gray-50" id="yorumlar">
  <div class="container-narrow">
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-bold text-primary-800 mb-4">
        Müşterilerimiz Ne Diyor?
      </h2>
      <p class="text-gray-600 max-w-2xl mx-auto">
        Binlerce mutlu müşterimizden bazılarının yorumları.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {testimonials.slice(0, 6).map((t) => (
        <div class="card flex flex-col">
          <!-- Stars -->
          <div class="flex gap-0.5 mb-3">
            {Array.from({ length: t.rating }).map(() => (
              <svg class="w-5 h-5 text-accent-400" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>

          <!-- Comment -->
          <p class="text-gray-600 text-sm leading-relaxed flex-1 mb-4">
            "{t.comment}"
          </p>

          <!-- Author -->
          <div class="flex items-center gap-3 pt-4 border-t border-gray-100">
            <div class="w-10 h-10 bg-primary-100 rounded-full flex items-center justify-center">
              <span class="text-primary-700 font-semibold text-sm">{t.name.charAt(0)}</span>
            </div>
            <div>
              <div class="font-semibold text-sm text-primary-800">{t.name}</div>
              <div class="text-xs text-gray-500">{t.title} {t.route && `• ${t.route}`}</div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
