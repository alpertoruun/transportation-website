---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
---

<BaseLayout
  title="Blog | Nakliyat Rehberi ve İpuçları"
  description="Evden eve nakliyat, taşınma ipuçları, paketleme teknikleri ve nakliyat fiyatları hakkında faydalı blog yazıları."
>
  <div class="max-w-7xl mx-auto px-4">
    <Breadcrumb items={[
      { label: 'Ana Sayfa', href: '/' },
      { label: 'Blog' },
    ]} />
  </div>

  <section class="bg-primary-800 py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 text-center">
      <h1 class="text-3xl md:text-5xl font-bold text-white mb-4">Blog</h1>
      <p class="text-gray-300 text-lg max-w-2xl mx-auto">
        Taşınma ipuçları, nakliyat rehberleri ve sektör hakkında faydalı bilgiler.
      </p>
    </div>
  </section>

  <section class="section-padding bg-white">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {posts.map((post) => (
          <a href={`/blog/${post.slug}/`} class="card group hover:border-accent-200 border border-transparent block">
            <div class="flex items-center gap-2 text-sm text-gray-500 mb-3">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
              {post.data.date.toLocaleDateString('tr-TR', { year: 'numeric', month: 'long', day: 'numeric' })}
            </div>
            <h2 class="text-lg font-bold text-primary-800 mb-2 group-hover:text-accent-600 transition-colors">
              {post.data.title}
            </h2>
            <p class="text-gray-600 text-sm leading-relaxed mb-4">{post.data.description}</p>
            <span class="text-accent-600 text-sm font-semibold inline-flex items-center gap-1 group-hover:gap-2 transition-all">
              Devamını Oku
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
