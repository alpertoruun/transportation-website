---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import { faqItems } from '../data/faq';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
};
---

<BaseLayout
  title="Sıkça Sorulan Sorular | Leventoğlu Nakliyat"
  description="Evden eve nakliyat hakkında merak ettiğiniz tüm sorular ve cevapları. Fiyatlar, sigorta, taşınma süreci ve daha fazlası."
  jsonLd={jsonLd}
>
  <div class="max-w-7xl mx-auto px-4">
    <Breadcrumb items={[
      { label: 'Ana Sayfa', href: '/' },
      { label: 'Sıkça Sorulan Sorular' },
    ]} />
  </div>

  <section class="bg-primary-800 py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 text-center">
      <h1 class="text-3xl md:text-5xl font-bold text-white mb-4">Sıkça Sorulan Sorular</h1>
      <p class="text-gray-300 text-lg max-w-2xl mx-auto">
        Nakliyat hizmetlerimiz hakkında en çok sorulan sorular ve cevapları.
      </p>
    </div>
  </section>

  <section class="section-padding bg-white">
    <div class="max-w-3xl mx-auto">
      <div class="space-y-4">
        {faqItems.map((item, index) => (
          <div class="border border-gray-200 rounded-xl overflow-hidden">
            <button
              class="faq-toggle w-full flex items-center justify-between p-5 text-left hover:bg-gray-50 transition-colors"
              aria-expanded="false"
            >
              <span class="font-semibold text-primary-800 pr-4">{item.question}</span>
              <svg class="faq-icon w-5 h-5 text-accent-500 shrink-0 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </button>
            <div class="faq-content hidden px-5 pb-5">
              <p class="text-gray-600 leading-relaxed">{item.answer}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  document.querySelectorAll('.faq-toggle').forEach((btn) => {
    btn.addEventListener('click', () => {
      const content = btn.nextElementSibling as HTMLElement;
      const icon = btn.querySelector('.faq-icon') as SVGElement;
      const isOpen = content.classList.toggle('hidden') === false;
      btn.setAttribute('aria-expanded', String(isOpen));
      icon.style.transform = isOpen ? 'rotate(180deg)' : '';
    });
  });
</script>
