---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import CTASection from '../../components/CTASection.astro';
import { services } from '../../data/services';
---

<BaseLayout
  title="Hizmetlerimiz | Leventoğlu Nakliyat"
  description="Leventoğlu Nakliyat hizmetleri: Evden eve nakliyat, ofis taşıma, şehirlerarası nakliyat, asansörlü taşıma, eşya paketleme ve depolama."
>
  <div class="max-w-7xl mx-auto px-4">
    <Breadcrumb items={[
      { label: 'Ana Sayfa', href: '/' },
      { label: 'Hizmetlerimiz' },
    ]} />
  </div>

  <section class="bg-primary-800 py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 text-center">
      <h1 class="text-3xl md:text-5xl font-bold text-white mb-4">Hizmetlerimiz</h1>
      <p class="text-gray-300 text-lg max-w-2xl mx-auto">
        Taşınma sürecinizin her adımında yanınızdayız. Profesyonel hizmetlerimizi keşfedin.
      </p>
    </div>
  </section>

  <section class="section-padding bg-white">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {services.map((service) => (
          <a href={`/hizmetlerimiz/${service.slug}/`} class="card group hover:border-accent-200 border border-transparent block">
            <div class="w-14 h-14 bg-primary-100 rounded-xl flex items-center justify-center mb-5 group-hover:bg-primary-600 transition-colors">
              <svg class="w-7 h-7 text-primary-600 group-hover:text-white transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={service.icon} />
              </svg>
            </div>
            <h2 class="text-xl font-bold text-primary-800 mb-3 group-hover:text-accent-600 transition-colors">{service.title}</h2>
            <p class="text-gray-600 text-sm leading-relaxed mb-4">{service.shortDesc}</p>
            <ul class="space-y-2 mb-5">
              {service.features.slice(0, 3).map((f) => (
                <li class="flex items-center gap-2 text-sm text-gray-600">
                  <svg class="w-4 h-4 text-accent-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  {f}
                </li>
              ))}
            </ul>
            <span class="text-accent-600 text-sm font-semibold inline-flex items-center gap-1 group-hover:gap-2 transition-all">
              Detaylı Bilgi
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <CTASection />
</BaseLayout>
