---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import CTASection from '../components/CTASection.astro';

const tasimaCount = 85;
const aracCount = 3;

const tasimaImages = Array.from({ length: tasimaCount }, (_, i) => ({
  src: `/images/tasima/evden-eve-nakliyat-${String(i + 1).padStart(2, '0')}.jpeg`,
  alt: `Evden eve nakliyat hizmeti - Leventoğlu Nakliyat ${i + 1}`,
}));

const aracImages = Array.from({ length: aracCount }, (_, i) => ({
  src: `/images/arac/nakliyat-araci-${String(i + 1).padStart(2, '0')}.jpeg`,
  alt: `Leventoğlu Nakliyat araç filosu ${i + 1}`,
}));
---

<BaseLayout
  title="Galeri | Nakliyat Fotoğraflarımız ve Araç Filomuz"
  description="Leventoğlu Nakliyat taşıma fotoğrafları, araç filosu ve çalışma görüntüleri. Profesyonel evden eve nakliyat hizmetlerimize göz atın."
>
  <div class="max-w-7xl mx-auto px-4">
    <Breadcrumb items={[
      { label: 'Ana Sayfa', href: '/' },
      { label: 'Galeri' },
    ]} />
  </div>

  <section class="bg-primary-800 py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 text-center">
      <h1 class="text-3xl md:text-5xl font-bold text-white mb-4">Galeri</h1>
      <p class="text-gray-300 text-lg max-w-2xl mx-auto">
        Taşıma süreçlerimizden ve araç filomuzdan görüntüler. Profesyonel hizmet anlayışımızı fotoğraflarla keşfedin.
      </p>
    </div>
  </section>

  <!-- Tabs -->
  <section class="section-padding bg-white">
    <div class="max-w-7xl mx-auto">
      <!-- Tab Buttons -->
      <div class="flex flex-wrap justify-center gap-3 mb-10">
        <button data-tab="tasima" class="tab-btn active px-6 py-3 rounded-full font-semibold text-sm transition-all">
          📦 Taşıma Fotoğrafları ({tasimaCount})
        </button>
        <button data-tab="arac" class="tab-btn px-6 py-3 rounded-full font-semibold text-sm transition-all">
          🚛 Araç Filomuz ({aracCount})
        </button>
        <button data-tab="video" class="tab-btn px-6 py-3 rounded-full font-semibold text-sm transition-all">
          🎬 Video (1)
        </button>
      </div>

      <!-- Taşıma Tab -->
      <div id="tab-tasima" class="tab-content">
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-3">
          {tasimaImages.map((img) => (
            <a href={img.src} target="_blank" rel="noopener" class="group relative aspect-square overflow-hidden rounded-lg bg-gray-100">
              <img
                src={img.src}
                alt={img.alt}
                class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-300"
                loading="lazy"
                decoding="async"
              />
              <div class="absolute inset-0 bg-black/0 group-hover:bg-black/20 transition-colors" />
            </a>
          ))}
        </div>
      </div>

      <!-- Araç Tab -->
      <div id="tab-arac" class="tab-content hidden">
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {aracImages.map((img) => (
            <a href={img.src} target="_blank" rel="noopener" class="group relative aspect-video overflow-hidden rounded-xl bg-gray-100">
              <img
                src={img.src}
                alt={img.alt}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                loading="lazy"
                decoding="async"
              />
              <div class="absolute inset-0 bg-black/0 group-hover:bg-black/20 transition-colors" />
            </a>
          ))}
        </div>
      </div>

      <!-- Video Tab -->
      <div id="tab-video" class="tab-content hidden">
        <div class="max-w-3xl mx-auto">
          <video
            controls
            preload="metadata"
            class="w-full rounded-xl shadow-lg"
            poster="/images/tasima/evden-eve-nakliyat-01.jpeg"
          >
            <source src="/images/video/nakliyat-sureci.mp4" type="video/mp4" />
            Tarayıcınız video oynatmayı desteklemiyor.
          </video>
          <p class="text-center text-gray-600 mt-4">Nakliyat sürecimizden bir kesit</p>
        </div>
      </div>
    </div>
  </section>

  <CTASection />
</BaseLayout>

<style>
  .tab-btn {
    background-color: #f3f4f6;
    color: #4b5563;
  }
  .tab-btn:hover {
    background-color: #e5e7eb;
  }
  .tab-btn.active {
    background-color: #1B3A5C;
    color: white;
  }
</style>

<script>
  document.querySelectorAll('.tab-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const tab = btn.getAttribute('data-tab');
      document.querySelectorAll('.tab-btn').forEach((b) => b.classList.remove('active'));
      btn.classList.add('active');
      document.querySelectorAll('.tab-content').forEach((c) => c.classList.add('hidden'));
      document.getElementById(`tab-${tab}`)?.classList.remove('hidden');
    });
  });
</script>
