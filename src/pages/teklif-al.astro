---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import { siteConfig } from '../data/site';
import { cities } from '../data/cities';

const whatsappUrl = `https://wa.me/${siteConfig.whatsapp}?text=${encodeURIComponent(siteConfig.whatsappDefault)}`;
---

<BaseLayout
  title="Teklif Al | Ücretsiz Nakliyat Fiyat Teklifi"
  description="Leventoğlu Nakliyat'tan ücretsiz evden eve nakliyat fiyat teklifi alın. WhatsApp ile anında dönüş. Şeffaf fiyatlandırma."
>
  <div class="max-w-7xl mx-auto px-4">
    <Breadcrumb items={[
      { label: 'Ana Sayfa', href: '/' },
      { label: 'Teklif Al' },
    ]} />
  </div>

  <section class="section-padding bg-white">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-10">
        <h1 class="text-3xl md:text-4xl font-bold text-primary-800 mb-4">Ücretsiz Nakliyat Teklifi Alın</h1>
        <p class="text-gray-600 max-w-2xl mx-auto">
          Bilgilerinizi doldurun, WhatsApp üzerinden size hemen dönüş yapalım.
          Ücretsiz keşif ve fiyat teklifi sunuyoruz.
        </p>
      </div>

      <div class="card max-w-2xl mx-auto">
        <form id="teklif-form" class="space-y-5">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
            <div>
              <label for="name" class="block text-sm font-medium text-gray-700 mb-1">Adınız Soyadınız</label>
              <input type="text" id="name" required class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-accent-500 focus:border-accent-500" placeholder="Adınız" />
            </div>
            <div>
              <label for="phone" class="block text-sm font-medium text-gray-700 mb-1">Telefon Numaranız</label>
              <input type="tel" id="phone" required class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-accent-500 focus:border-accent-500" placeholder="05XX XXX XX XX" />
            </div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
            <div>
              <label for="from-city" class="block text-sm font-medium text-gray-700 mb-1">Nereden</label>
              <select id="from-city" required class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-accent-500 focus:border-accent-500 bg-white">
                <option value="">Şehir seçin</option>
                {cities.map((city) => (
                  <option value={city.name}>{city.name}</option>
                ))}
              </select>
            </div>
            <div>
              <label for="to-city" class="block text-sm font-medium text-gray-700 mb-1">Nereye</label>
              <select id="to-city" required class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-accent-500 focus:border-accent-500 bg-white">
                <option value="">Şehir seçin</option>
                {cities.map((city) => (
                  <option value={city.name}>{city.name}</option>
                ))}
              </select>
            </div>
          </div>

          <div>
            <label for="date" class="block text-sm font-medium text-gray-700 mb-1">Tahmini Taşınma Tarihi</label>
            <input type="date" id="date" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-accent-500 focus:border-accent-500" />
          </div>

          <div>
            <label for="note" class="block text-sm font-medium text-gray-700 mb-1">Ek Bilgi (Opsiyonel)</label>
            <textarea id="note" rows="3" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-accent-500 focus:border-accent-500" placeholder="Taşınma detayları, oda sayısı, özel eşyalar vb."></textarea>
          </div>

          <button type="submit" class="btn-whatsapp w-full py-4 text-base">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" /></svg>
            WhatsApp ile Teklif Al
          </button>
        </form>
      </div>
    </div>
  </section>
</BaseLayout>

<script define:vars={{ whatsappNumber: siteConfig.whatsapp }}>
  document.getElementById('teklif-form')?.addEventListener('submit', (e) => {
    e.preventDefault();
    const name = (document.getElementById('name') as HTMLInputElement).value;
    const phone = (document.getElementById('phone') as HTMLInputElement).value;
    const from = (document.getElementById('from-city') as HTMLSelectElement).value;
    const to = (document.getElementById('to-city') as HTMLSelectElement).value;
    const date = (document.getElementById('date') as HTMLInputElement).value;
    const note = (document.getElementById('note') as HTMLTextAreaElement).value;

    let message = `Merhaba, nakliyat teklifi almak istiyorum.\n\n`;
    message += `Ad: ${name}\n`;
    message += `Telefon: ${phone}\n`;
    message += `Nereden: ${from}\n`;
    message += `Nereye: ${to}\n`;
    if (date) message += `Tahmini Tarih: ${date}\n`;
    if (note) message += `Not: ${note}\n`;

    window.open(`https://wa.me/${whatsappNumber}?text=${encodeURIComponent(message)}`, '_blank');
  });
</script>
